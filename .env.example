# ══════════════════════════════════════════════════════════════════════════════
# NON-SENSITIVE CONFIG — safe to keep in project .env (gitignored)
# ══════════════════════════════════════════════════════════════════════════════

# ─── Polymarket APIs ────────────────────────────────────────────────────────
CLOB_API_URL=https://clob.polymarket.com
GAMMA_API_URL=https://gamma-api.polymarket.com
DATA_API_URL=https://data-api.polymarket.com
SUBGRAPH_URL=https://api.thegraph.com/subgraphs/name/polymarket/polymarket-matic

# ─── Database ───────────────────────────────────────────────────────────────
DATABASE_PATH=data/polymarket.db

# ─── Network ────────────────────────────────────────────────────────────────
CHAIN_ID=137
POLYGON_RPC_URL=https://polygon-rpc.com

# ─── Safety Controls ────────────────────────────────────────────────────────
# KEEP DRY_RUN=true until you've verified everything works end-to-end
DRY_RUN=true
MAX_ORDER_SIZE_USDC=100

# ─── Copy Trading Engine ─────────────────────────────────────────────────────
# How often to check the global trade stream for new whale activity (seconds)
STREAM_INTERVAL_SECONDS=60
# How often to do a full snapshot refresh of all whale positions (seconds)
MONITOR_INTERVAL_SECONDS=300
# Your trading capital in USDC used for Kelly sizing
PORTFOLIO_SIZE=1000
# Fraction of full Kelly to bet (0.25 = 25% — conservative)
KELLY_CAP=0.25
# Minimum ROI for a whale wallet to be copied (0.05 = 5%)
MIN_WHALE_ROI=0.05
# Minimum resolved trades for a whale wallet
MIN_WHALE_TRADES=30
# Maximum p-value for statistical significance (0.05 = 5%)
MIN_WHALE_PVALUE=0.05
# Ignore whale positions smaller than this USDC value
MIN_POSITION_USDC=10
# Maximum number of simultaneously open positions (hard cap)
MAX_OPEN_POSITIONS=20
# Repricing guard: skip if currentAsk < this ratio * whaleAvgPrice (whale's market collapsed)
MIN_WHALE_ASK_RATIO=0.5
# Minimum edge (whaleAvgPrice - currentAsk) to enter. 0.05 = skip if whale's thesis priced in by 95%+
MIN_EDGE=0.05
# Only copy whale's first entry into a market. Set false to also copy position-growth signals.
FIRST_ENTRY_ONLY=true

# ─── WebSocket Live Streaming ───────────────────────────────────────────────
# Maximum number of simultaneously subscribed market token IDs via WebSocket.
# Only active (non-resolved) markets are subscribed; increase if you track many whales.
WS_MAX_SUBSCRIPTIONS=2000
# Minutes before a WS-detected signal is no longer considered a duplicate of
# a polling-cycle signal for the same position (prevents double-entry)
WS_SIGNAL_DEDUP_MINUTES=30
# Days to retain live_events rows in the database
LIVE_EVENTS_RETENTION_DAYS=7

# ─── Logging ────────────────────────────────────────────────────────────────
LOG_LEVEL=info
LOG_PRETTY=true

# ─── Telegram Alerts (optional) ─────────────────────────────────────────────
# Create a bot via @BotFather, then add it to a chat and get the chat ID
# via https://api.telegram.org/bot<TOKEN>/getUpdates
# Leave blank to disable alerts
# TELEGRAM_BOT_TOKEN=123456:ABC-DEF...
# TELEGRAM_CHAT_ID=-1001234567890

# ══════════════════════════════════════════════════════════════════════════════
# SECRETS — store in ~/.polymarket-secrets, NOT here
# ══════════════════════════════════════════════════════════════════════════════
# PRIVATE_KEY=0x...
# POLYMARKET_PROXY_ADDRESS=0x...   (optional)
#
# After running `pnpm dev orders derive-keys`:
# CLOB_API_KEY=...
# CLOB_SECRET=...
# CLOB_PASSPHRASE=...
